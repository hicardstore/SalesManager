rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    match /projects/{projectId} {
      allow read, get, list: if request.auth != null && (
        resource.data.ownerEmail.lower() == request.auth.token.email.lower() 
        || request.auth.token.email.lower() in resource.data.memberEmails
      );
      allow create: if request.auth != null && isValidId(projectId) && (
        request.resource.data.ownerEmail.lower() == request.auth.token.email.lower()
        && request.auth.token.email.lower() in request.resource.data.memberEmails
      );
      allow update: if request.auth != null && (
        resource.data.ownerEmail.lower() == request.auth.token.email.lower()
        || request.auth.token.email.lower() in resource.data.memberEmails
      );
      allow delete: if request.auth != null && resource.data.ownerEmail.lower() == request.auth.token.email.lower();
    }
    
    match /operations/{operationId} {
      allow read, list: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        resource.data.projectId == request.auth.uid ||
        (resource.data.projectId != null && request.auth.token.email != null && 
         exists(/databases/$(database)/documents/projects/$(resource.data.projectId)) &&
         request.auth.token.email.lower() in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.memberEmails)
      );
      allow create: if request.auth != null && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.projectId == request.auth.uid ||
        (request.resource.data.projectId != null && request.auth.token.email != null && 
         exists(/databases/$(database)/documents/projects/$(request.resource.data.projectId)) &&
         request.auth.token.email.lower() in get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.memberEmails)
      );
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.projectId == request.auth.uid ||
        (resource.data.projectId != null && request.auth.token.email != null && 
         exists(/databases/$(database)/documents/projects/$(resource.data.projectId)) &&
         request.auth.token.email.lower() in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.memberEmails)
      );
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.projectId == request.auth.uid
      );
    }
  }
}
